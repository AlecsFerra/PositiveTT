import SPos.Syntax.Syntax

abbrev Ctx := Env Tm

section
set_option hygiene false
notation:40 "вКҐ" ќУ:40 => WfCtx ќУ
notation:40 ќУ:41 "вКҐ" a:41 "вИґ" A:41 => WfTm ќУ a A
notation:40 ќУ:41 "вИЛ" x:41 "вИґ" ѕД:41 => Lookup ќУ x ѕД
notation:40 ќУ:41 "вКҐ" t:41 "вЙ°" t':41 "вИґ" ѕД:41 => DefEq ќУ t t' ѕД

inductive Lookup : Ctx n вЖТ Fin n вЖТ Tm n вЖТ Prop where
| here  : ќУ вИЈ ѕД вИЛ 0 вИґ вЖС ѕД
| there : ќУ вИЛ n вИґ ѕД вЖТ ќУ вИЈ ѕЕ вИЛ n.succ вИґ вЖС ѕД

mutual
inductive WfCtx : Ctx n вЖТ Prop where
| nil  : вКҐ вИЕ
| cons : вКҐ ќУ вЖТ ќУ вКҐ ѕД вИґ рЭУ§ вДУ вЖТ вКҐ ќУ вИЈ ѕД

inductive WfTm : Ctx n вЖТ Tm n вЖТ Tm n вЖТ Prop where
| var : вКҐ ќУ вЖТ ќУ вИЛ x вИґ ѕД вЖТ ќУ вКҐ # x вИґ ѕД
| conv : ќУ вКҐ t вИґ ѕД вЖТ ќУ вКҐ ѕГ вИґ рЭУ§ вДУ вЖТ ќУ вКҐ ѕД вЙ° ѕГ вИґ рЭУ§ вДУ вЖТ ќУ вКҐ t вИґ ѕГ
-- Pi
| pi  : ќУ вКҐ ѕД вИґ рЭУ§ вДУвВБ вЖТ ќУ вИЈ ѕД вКҐ ѕЕ вИґ рЭУ§ вДУвВВ вЖТ ќУ вКҐ ќ† ѕД ѕЕ вИґ рЭУ§ (max вДУвВБ вДУвВВ)
| lam : ќУ вКҐ ѕД вИґ рЭУ§ вДУ вЖТ ќУ вИЈ ѕД вКҐ ѕГ вИґ рЭУ§ вДУ' вЖТ ќУ вИЈ ѕД вКҐ t вИґ ѕГ вЖТ ќУ вКҐ ∆Ы ѕД t вИґ (ќ† ѕД ѕГ)
| app : ќУ вКҐ t вИґ (ќ† ѕД ѕГ) вЖТ ќУ вКҐ m вИґ ѕД вЖТ ќУ вКҐ t вАҐ m вИґ ѕГ [/ m ]
-- Identity
| id   : ќУ вКҐ ѕД вИґ рЭУ§ вДУ вЖТ ќУ вКҐ a вИґ ѕД вЖТ ќУ вКҐ b вИґ ѕД вЖТ ќУ вКҐ Id ѕД a b вИґ рЭУ§ вДУ
| refl : ќУ вКҐ a вИґ ѕД вЖТ ќУ вКҐ refl ѕД a вИґ Id ѕД a a
| j {a : Tm n} : ќУ вКҐ ѕД вИґ рЭУ§ вДУвВБ вЖТ
      ќУ вИЈ ѕД вКҐ Id (вЖС ѕД) (вЖС a) # 0 вИґ рЭУ§ вДУвВБ вЖТ
      ќУ вИЈ ѕД вИЈ Id (вЖС ѕД) (вЖС a) # 0 вКҐ C вИґ рЭУ§ вДУ вЖТ
      ќУ вКҐ p вИґ Id ѕД a b вЖТ
      ќУ вКҐ d вИґ C [/ refl (вЖС ѕД) (вЖС a) ] [/ a ] вЖТ
      ќУ вКҐ J C d p вИґ C [/ вЖС p ] [/ b ]
-- Universe
| u : вКҐ ќУ вЖТ ќУ вКҐ рЭУ§ вДУ вИґ рЭУ§ (вДУ + 1)

inductive DefEq : Ctx n вЖТ Tm n вЖТ Tm n вЖТ Tm n вЖТ Prop where
| refl  : ќУ вКҐ t вИґ ѕД вЖТ ќУ вКҐ t вЙ° t вИґ ѕД
| symm  : ќУ вКҐ t вЙ° t' вИґ ѕД вЖТ ќУ вКҐ t' вЙ° t вИґ ѕД
| trans : ќУ вКҐ t вЙ° t' вИґ ѕД вЖТ ќУ вКҐ t' вЙ° t'' вИґ ѕД вЖТ ќУ вКҐ t вЙ° t'' вИґ ѕД
-- Pi
| pi : ќУ вКҐ ѕД вИґ рЭУ§ вДУвВБ вЖТ ќУ вКҐ ѕД вЙ° ѕД' вИґ рЭУ§ вДУвВБ вЖТ ќУ вИЈ ѕД вКҐ ѕЕ вЙ° ѕЕ' вИґ рЭУ§ вДУвВВ вЖТ ќУ вКҐ ќ† ѕД ѕЕ вЙ° ќ† ѕД' ѕЕ' вИґ рЭУ§ (max вДУвВБ вДУвВВ)
| lam : ќУ вКҐ ѕД вИґ рЭУ§ вДУ вЖТ ќУ вИЈ ѕД вКҐ ѕГ вИґ рЭУ§ вДУ' вЖТ ќУ вКҐ ѕД вЙ° ѕД' вИґ рЭУ§ вДУ вЖТ ќУ вИЈ ѕД вКҐ t вЙ° t' вИґ ѕГ вЖТ ќУ вКҐ ∆Ы ѕД t вЙ° ∆Ы ѕД' t' вИґ (ќ† ѕД ѕГ)
| app : ќУ вКҐ t вЙ° t' вИґ (ќ† ѕД ѕГ) вЖТ ќУ вКҐ m вЙ° m' вИґ ѕД вЖТ ќУ вКҐ t вАҐ m вЙ° t' вАҐ m' вИґ ѕГ [/ m ]
| lamќ≤ : ќУ вКҐ ∆Ы ѕД t вИґ (ќ† ѕД ѕГ) вЖТ ќУ вКҐ m вИґ ѕД вЖТ ќУ вКҐ (∆Ы ѕД t) вАҐ m вЙ° t [/ m ] вИґ ѕГ [/ m ]
| lamќЈ : ќУ вКҐ t вИґ ќ† ѕД ѕЕ вЖТ ќУ вКҐ t вЙ° ∆Ы ѕД (вЖС t) вАҐ # 0 вИґ ќ† ѕД ѕЕ
-- Identity
| id : ќУ вКҐ ѕД вЙ° ѕД' вИґ рЭУ§ вДУ вЖТ ќУ вКҐ a вЙ° a' вИґ ѕД вЖТ ќУ вКҐ b вЙ° b' вИґ ѕД вЖТ
       ќУ вКҐ Id ѕД a b вЙ° Id ѕД' a' b' вИґ рЭУ§ вДУ
| reflId : ќУ вКҐ ѕД вЙ° ѕД' вИґ рЭУ§ вДУ вЖТ ќУ вКҐ a вЙ° a' вИґ ѕД вЖТ ќУ вКҐ refl ѕД a вЙ° refl ѕД' a' вИґ Id ѕД a a
| j {a : Tm n} : ќУ вКҐ ѕД вИґ рЭУ§ вДУвВБ вЖТ
      ќУ вИЈ ѕД вКҐ Id (вЖС ѕД) (вЖС a) # 0 вИґ рЭУ§ вДУвВБ вЖТ
      ќУ вИЈ ѕД вИЈ Id (вЖС ѕД) (вЖС a) # 0 вКҐ C вЙ° C' вИґ рЭУ§ вДУ вЖТ
      ќУ вКҐ d вЙ° d' вИґ C [/ refl (вЖС ѕД) (вЖС a) ] [/ a ] вЖТ
      ќУ вКҐ p вЙ° p' вИґ Id ѕД a b вЖТ
      ќУ вКҐ J C d p вЙ° J C' d' p' вИґ C [/ вЖС p ] [/ b ]
| jќ≤ : ќУ вКҐ ѕД вИґ рЭУ§ вДУвВБ вЖТ ќУ вКҐ a вИґ ѕД вЖТ
       ќУ вИЈ ѕД вКҐ Id (вЖС ѕД) (вЖС a) # 0 вИґ рЭУ§ вДУвВБ вЖТ
       ќУ вИЈ ѕД вИЈ Id (вЖС ѕД) (вЖС a) # 0 вКҐ C вИґ рЭУ§ вДУ вЖТ
       ќУ вКҐ d вИґ C [/ refl (вЖС ѕД) (вЖС a) ] [/ a ] вЖТ
       ќУ вКҐ J C d (refl ѕД a) вЙ° d вИґ C [/ refl (вЖС ѕД) (вЖС a) ] [/ a ]
end
end
